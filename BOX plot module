suppressPackageStartupMessages({
  library(Seurat)
  library(dplyr)
  library(ggplot2)
})

# Load
obj <- readRDS("601_72h_filtered.rds")

# Latest NODAL score column
nodal_cols <- grep("^NODAL\\d+$", colnames(obj@meta.data), value = TRUE)
nodal_col  <- nodal_cols[length(nodal_cols)]

# Cluster order you want
keep_clusters <- c(
  "Anterior Primitive Streak",
  "Primitive Streak",
  "Nascent mesoderm",
  "Intermediate mesoderm",
  "Caudal epiblast",
  "Ectoderm",
  "Neural tube",
  "Epiblast",
  "PGC",
  "Parietal endoderm",
  "Visceral endoderm"
)

# Make a plotting data.frame
dfp <- FetchData(
  obj,
  vars = c(nodal_col, "group", "sc_merged_gast_transfer_label")
)
colnames(dfp)[1] <- "nodal"

# Keep only selected clusters + enforce order
dfp <- dfp %>%
  filter(sc_merged_gast_transfer_label %in% keep_clusters) %>%
  mutate(
    sc_merged_gast_transfer_label = factor(sc_merged_gast_transfer_label, levels = keep_clusters),
    group = factor(as.character(group), levels = c("Ctrl","RACL","NACL","XAL"))
  )

# Condition colors (NACLB might be coded as "NACL" in your metadata)
cond_colors <- c(
  "Ctrl" = "#A6CEE3",   # light blue
  "RACL" = "#E31A1C",   # bright red
  "NACL" = "#33A02C",   # green
  "XAL"  = "#FFD700"    # yellow
)

p_box <- ggplot(dfp, aes(x = sc_merged_gast_transfer_label, y = nodal, fill = group)) +
  geom_boxplot(
    outlier.size = 0.2,
    linewidth = 0.25,
    position = position_dodge(width = 0.8)
  ) +
  scale_fill_manual(values = cond_colors, drop = FALSE) +
  theme_minimal(base_size = 12) +
  theme(
    axis.title.x = element_blank(),
    axis.title.y = element_blank(),
    axis.text.x = element_text(angle = 45, hjust = 1),
    legend.title = element_blank()
  ) +
  labs(y = "NODAL module score")

p_box

ggsave("601_72h_NODAL_boxplot_clusters_ordered.pdf", p_box, width = 12, height = 4, useDingbats = FALSE)
ggsave("601_72h_NODAL_boxplot_clusters_ordered.png", p_box, width = 12, height = 4, dpi = 300)
