  "HH"       = "#33A02C",
  "MDK"      = "#E41A1C",
  "BMP"      = "#1F78B4",
  "PDGF"     = "#984EA3",
  "LAMININ"  = "#FF7F00",
  "COLLAGEN" = "#A65628",
  "FGF"      = "#F781BF",
  "VEGF"     = "#00CED1",
  "WNT"      = "#FFD700",
  "ncWNT"    = "#00008B",
  "TGFb"     = "#8B0000",
  "NOTCH"    = "#000000",
  "IGF"      = "#6A3D9A"
)

missing_pathways <- setdiff(pathways, names(pathway_colors_manual))

if (length(missing_pathways) > 0) {
  pathway_colors_manual <- c(
    pathway_colors_manual,
    setNames(
      colorRampPalette(c(
        "#E41A1C", "#377EB8", "#4DAF4A", "#984EA3",
        "#FF7F00", "#000000"
      ))(length(missing_pathways)),
