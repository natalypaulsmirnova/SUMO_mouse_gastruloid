# =========================================================
# CELLCHAT 120h — Notochord sender -> mesodermal clusters
# TOP 10 pathways + force-include HH
# ORIGINAL source/target names used
# Legend UNDERNEATH
# Saves to: E:/GRAPHS
# =========================================================

library(readxl)
library(dplyr)
library(tidyr)
library(circlize)

cellchat_file <- "F:/CELLCHAT.xlsx"
output_dir <- "E:/GRAPHS"
dir.create(output_dir, showWarnings = FALSE, recursive = TRUE)

timepoint <- "120h"

noto_cluster <- "Notochord"

mesoderm_clusters <- c(
  "Cardiopharyngeal mesoderm",
  "Dermomyotome",
  "Embryo proper endothelium",
  "Endotome",
  "Kidney primordium",
  "Limb mesoderm",
  "Posterior somitic tissues",
  "Sclerotome",
  "Venous endothelium"
)

force_include_pathways <- c("HH")

clean_colnames <- function(x) {
  x <- tolower(x)
  x <- gsub("\\s+", "_", x)
  x <- gsub("[^a-z0-9_]", "", x)
  x
}

read_cellchat_sheet <- function(sheet_name, condition_name) {
  
  raw <- read_excel(cellchat_file, sheet = sheet_name, col_names = FALSE)
  
  header_row <- which(apply(raw, 1, function(r) {
    any(grepl("^source$", tolower(as.character(r)))) &&
      any(grepl("^target$", tolower(as.character(r))))
  }))[1]
  
  if (is.na(header_row)) {
    stop(paste0("Could not find source/target header in sheet: ", sheet_name))
  }
  
  x <- read_excel(
    cellchat_file,
    sheet = sheet_name,
    skip = header_row - 1,
    col_types = "text"
  )
  
  colnames(x) <- clean_colnames(colnames(x))
  
  x %>%
    mutate(
      condition = condition_name,
      time = timepoint
    )
}

# =========================================================
# Load 120h sheets
# =========================================================

all_sheets <- excel_sheets(cellchat_file)

sheet_map <- data.frame(
  sheet = all_sheets[grepl(gsub("h", "", timepoint), all_sheets)],
  stringsAsFactors = FALSE
) %>%
  mutate(
    condition = case_when(
      grepl("ctrl|control", sheet, ignore.case = TRUE) ~ "Control",
      grepl("racl", sheet, ignore.case = TRUE) ~ "RACL",
      grepl("nacl|naclb", sheet, ignore.case = TRUE) ~ "NACLB",
      grepl("xal", sheet, ignore.case = TRUE) ~ "XAL",
      TRUE ~ NA_character_
    )
  ) %>%
  filter(!is.na(condition))

print(sheet_map)

df <- bind_rows(
  lapply(seq_len(nrow(sheet_map)), function(i) {
    read_cellchat_sheet(
      sheet_name = sheet_map$sheet[i],
      condition_name = sheet_map$condition[i]
    )
  })
)

df <- df %>%
  mutate(
    source = as.character(.data$source),
    target = as.character(.data$target),
    ligand = as.character(.data$ligand),
    receptor = as.character(.data$receptor),
    pathway_name = as.character(.data$pathway_name),
    prob = as.numeric(.data$prob)
  ) %>%
  filter(
    !is.na(source),
    !is.na(target),
    !is.na(pathway_name),
    !is.na(prob),
    prob > 0
  )

# =========================================================
# Filter: Notochord sender -> mesodermal targets
# =========================================================

df_noto_meso_all <- df %>%
  filter(
    source == noto_cluster,
    target %in% mesoderm_clusters
  )

if (nrow(df_noto_meso_all) == 0) {
  stop("No Notochord -> mesoderm interactions found. Check source/target names.")
}

# =========================================================
# Select TOP 10 pathways globally + force include HH
# =========================================================

top10_pathways <- df_noto_meso_all %>%
  group_by(pathway_name) %>%
  summarise(total_prob = sum(prob, na.rm = TRUE), .groups = "drop") %>%
  arrange(desc(total_prob)) %>%
  slice_head(n = 10) %>%
  pull(pathway_name)

pathways_keep <- unique(c(top10_pathways, force_include_pathways))

# Only keep forced pathways if they actually exist in this filtered data
pathways_keep <- pathways_keep[pathways_keep %in% unique(df_noto_meso_all$pathway_name)]

df_noto_meso <- df_noto_meso_all %>%
  filter(pathway_name %in% pathways_keep)

print("Pathways included:")
print(pathways_keep)

print(table(df_noto_meso$condition))
print(sort(unique(df_noto_meso$source)))
print(sort(unique(df_noto_meso$target)))
print(sort(unique(df_noto_meso$pathway_name)))

# =========================================================
# Colors
# =========================================================

pathways <- pathways_keep

