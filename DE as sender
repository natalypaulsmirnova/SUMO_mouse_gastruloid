# =========================================================
# Global scaling
# =========================================================

global_max_prob <- df_gut_sender %>%
  group_by(source, target, pathway_name, condition) %>%
  summarise(prob = sum(prob, na.rm = TRUE), .groups = "drop") %>%
  summarise(max_prob = max(prob, na.rm = TRUE)) %>%
  pull(max_prob)

# =========================================================
# Plot one chord
# =========================================================

plot_gut_sender_chord <- function(condition_use,
                                  min_prob = 0.001,
                                  top_edges = 80,
                                  label_cex = 0.75) {
  
  dat <- df_gut_sender %>%
    filter(
      condition == condition_use,
      prob >= min_prob
    ) %>%
    group_by(source, target, pathway_name) %>%
    summarise(prob = sum(prob, na.rm = TRUE), .groups = "drop") %>%
    arrange(desc(prob))
  
  if (!is.null(top_edges)) {
    dat <- dat %>% slice_head(n = top_edges)
  }
  
  if (nrow(dat) == 0) {
    plot.new()
    title(paste0(condition_use, " ", timepoint, "\nNo gut-sender interactions"))
    return(NULL)
  }
  
  dat <- dat %>%
    mutate(
      scaled_prob = prob / global_max_prob,
      scaled_prob = pmax(scaled_prob, 0.04)
    )
  
  sectors_here <- unique(c(dat$source, dat$target))
  
  local_order <- c(
    cell_order[cell_order %in% sectors_here],
    setdiff(sectors_here, cell_order)
  )
  
  local_cell_colors <- cell_colors[local_order]
  
  edge_cols <- pathway_colors[dat$pathway_name]
  edge_cols[is.na(edge_cols)] <- "#999999"
  
  circos.clear()
  circos.par(
    gap.degree = 6,
    start.degree = 90,
    track.margin = c(0.01, 0.01),
    points.overflow.warning = FALSE
  )
  
  chordDiagram(
    x = dat[, c("source", "target", "scaled_prob")],
    order = local_order,
    grid.col = local_cell_colors,
    col = edge_cols,
    transparency = 0.18,
    directional = 1,
    direction.type = c("arrows", "diffHeight"),
    diffHeight = -0.035,
    link.arr.type = "big.arrow",
    link.sort = TRUE,
    link.decreasing = FALSE,
    annotationTrack = "grid",
    preAllocateTracks = list(track.height = 0.20)
  )
  
  circos.trackPlotRegion(
    track.index = 1,
    panel.fun = function(x, y) {
      sector.name <- get.cell.meta.data("sector.index")
      xlim <- get.cell.meta.data("xlim")
      ylim <- get.cell.meta.data("ylim")
      
      circos.text(
        x = mean(xlim),
        y = ylim[1] + 0.18,
        labels = sector.name,
        facing = "clockwise",
        niceFacing = TRUE,
        adj = c(0, 0.5),
        cex = label_cex
      )
    },
    bg.border = NA
  )
  
  title(
    paste0(condition_use, " ", timepoint, " — gut regions as senders"),
    cex.main = 1.1,
    font.main = 2
  )
}

# =========================================================
# Panel with legend underneath
# =========================================================

plot_gut_sender_panel <- function(min_prob = 0.001,
                                  top_edges = 80,
                                  label_cex = 0.75,
                                  save_pdf = TRUE,
                                  show_in_R = TRUE) {
  
  draw_panel <- function() {
    
    layout(
      matrix(c(
        1, 2,
        3, 4,
        5, 5
      ), nrow = 3, byrow = TRUE),
      widths = c(1, 1),
      heights = c(1, 1, 0.32)
    )
    
    par(mar = c(1, 1, 3, 1))
    
    for (cond in condition_order) {
      plot_gut_sender_chord(
        condition_use = cond,
        min_prob = min_prob,
        top_edges = top_edges,
        label_cex = label_cex
      )
    }
    
    par(mar = c(0, 1, 0, 1))
    plot.new()
    
    legend(
      "center",
      legend = pathways,
      col = pathway_colors[pathways],
      lwd = 6,
      cex = 0.75,
      bty = "n",
      title = "Pathway",
      horiz = TRUE,
      x.intersp = 0.75,
      y.intersp = 1.1
    )
    
    layout(1)
  }
  
  if (save_pdf) {
    pdf_file <- file.path(
      output_dir,
      paste0(timepoint, "_Gut_regions_as_senders_ALL_pathways_chord_panel.pdf")
    )
    
    pdf(
      pdf_file,
      width = 30 / 2.54,
      height = 25 / 2.54,
      useDingbats = FALSE
    )
    
    draw_panel()
    dev.off()
    message("Saved: ", pdf_file)
  }
  
  if (show_in_R) {
    draw_panel()
  }
}

# =========================================================
# Run
# =========================================================

plot_gut_sender_panel(
  min_prob = 0.001,
  top_edges = 80,
  label_cex = 0.75,
  save_pdf = TRUE,
  show_in_R = TRUE
)
