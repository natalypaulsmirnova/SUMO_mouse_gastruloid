# =========================================================
# GLOBAL SCALING ACROSS 72h CONDITIONS
# =========================================================

global_max_prob <- df %>%
  group_by(source, target, pathway_name, condition) %>%
  summarise(prob = sum(prob, na.rm = TRUE), .groups = "drop") %>%
  summarise(max_prob = max(prob, na.rm = TRUE)) %>%
  pull(max_prob)

# =========================================================
# PLOT ONE CHORD
# =========================================================

plot_one_chord <- function(data,
                           pathway_use,
                           condition_use,
                           min_prob = 0.001,
                           top_edges = 35,
                           label_cex = 0.75) {
  
  dat <- data %>%
    filter(
      pathway_name == pathway_use,
      condition == condition_use,
      prob >= min_prob
    ) %>%
    group_by(source, target, pathway_name) %>%
    summarise(prob = sum(prob, na.rm = TRUE), .groups = "drop") %>%
    arrange(desc(prob))
  
  if (!is.null(top_edges)) {
    dat <- dat %>% slice_head(n = top_edges)
  }
  
  if (nrow(dat) == 0) {
    plot.new()
    title(paste0(condition_use, " — ", pathway_use, "\nNo interactions"))
    return(NULL)
  }
  
  dat <- dat %>%
    mutate(
      scaled_prob = prob / global_max_prob,
      scaled_prob = pmax(scaled_prob, 0.03)
    )
  
  edge_cols <- rep(pathway_colors[pathway_use], nrow(dat))
  edge_cols[is.na(edge_cols)] <- "#999999"
  
  sectors_here <- unique(c(dat$source, dat$target))
  local_order <- c(
    cluster_order[cluster_order %in% sectors_here],
    setdiff(sectors_here, cluster_order)
  )
  
  local_cluster_colors <- cluster_colors[local_order]
  
  missing_sector_colors <- setdiff(local_order, names(local_cluster_colors))
  if (length(missing_sector_colors) > 0) {
    local_cluster_colors <- c(
      local_cluster_colors,
      setNames(rep("#BDBDBD", length(missing_sector_colors)), missing_sector_colors)
    )
  }
  local_cluster_colors <- local_cluster_colors[local_order]
  
  circos.clear()
  circos.par(
    gap.degree = 6,
    start.degree = 90,
    track.margin = c(0.01, 0.01),
    points.overflow.warning = FALSE
  )
  
  chordDiagram(
    x = dat[, c("source", "target", "scaled_prob")],
    order = local_order,
    grid.col = local_cluster_colors,
    col = edge_cols,
    transparency = 0.45,
    directional = 1,
    direction.type = c("arrows", "diffHeight"),
    diffHeight = -0.035,
    link.arr.type = "big.arrow",
    link.sort = TRUE,
    link.decreasing = FALSE,
    annotationTrack = "grid",
    preAllocateTracks = list(track.height = 0.16)
  )
  
  circos.trackPlotRegion(
    track.index = 1,
    panel.fun = function(x, y) {
      sector.name <- get.cell.meta.data("sector.index")
      xlim <- get.cell.meta.data("xlim")
      ylim <- get.cell.meta.data("ylim")
      
      circos.text(
        x = mean(xlim),
        y = ylim[1] + 0.14,
        labels = sector.name,
        facing = "clockwise",
        niceFacing = TRUE,
        adj = c(0, 0.5),
        cex = label_cex
      )
    },
    bg.border = NA
  )
  
  title(
    paste0(condition_use, " 72h — ", pathway_use),
    cex.main = 1.0,
    font.main = 2
  )
}

# =========================================================
# PATHWAY PANEL: 4 CONDITIONS
# =========================================================

plot_pathway_panel_72h <- function(pathway_use,
                                   min_prob = 0.001,
                                   top_edges = 35,
                                   label_cex = 0.75,
                                   save_pdf = TRUE,
                                   show_in_R = TRUE) {
  
  if (save_pdf) {
    pdf_file <- file.path(
      output_dir,
      paste0("72h_", pathway_use, "_grouped_chord_panel_pathway_color.pdf")
    )
    
    pdf(
      pdf_file,
      width = 28 / 2.54,
      height = 20 / 2.54,
      useDingbats = FALSE
    )
  }
  
  par(mfrow = c(2, 2), mar = c(1, 1, 3, 1))
  
  for (cond in condition_order) {
    plot_one_chord(
      data = df,
      pathway_use = pathway_use,
      condition_use = cond,
      min_prob = min_prob,
      top_edges = top_edges,
      label_cex = label_cex
    )
  }
  
  par(mfrow = c(1, 1))
  
  if (save_pdf) {
    dev.off()
    message("Saved: ", pdf_file)
  }
  
  if (show_in_R) {
    par(mfrow = c(2, 2), mar = c(1, 1, 3, 1))
    
    for (cond in condition_order) {
      plot_one_chord(
        data = df,
        pathway_use = pathway_use,
        condition_use = cond,
        min_prob = min_prob,
        top_edges = top_edges,
        label_cex = label_cex
      )
    }
    
    par(mfrow = c(1, 1))
  }
}

