# =========================================================
# MANUAL CLUSTER GROUPING
# =========================================================

group_cluster <- function(x) {
  case_when(
    x %in% c("ExE ectoderm", "ExE ectoderm artifact") ~ "ExE ectoderm artifact",
    
    x %in% c(
      "ExE endoderm", "Visceral endoderm", "Parietal endoderm",
      "VE", "PE"
    ) ~ "Extraembryonic endoderm-like",
    
    x %in% c(
      "PGC", "Primordial germ cells", "Pluripotent cells", "PGC/Pluri"
    ) ~ "PGC/Pluri",
    
    x %in% c("Epiblast", "Epiblast (Epi)", "Epi") ~ "Epiblast (Epi)",
    
    x %in% c(
      "Primitive Streak", "Primitive streak", "PS",
      "Anterior Primitive Streak", "Anterior primitive streak", "APS"
    ) ~ "Primitive Streak (PS)",
    
    x %in% c("Nascent mesoderm", "Nascent meso") ~ "Nascent meso",
    
    x %in% c("Caudal epiblast") ~ "Caudal epiblast",
    
    x %in% c("Ectoderm") ~ "Ectoderm",
    
    x %in% c("Neural tube", "Neural Tube") ~ "Neural tube",
    
    x %in% c(
      "Spinal cord", "Spinal cord progenitors", "Spinal cord progenitor"
    ) ~ "Spinal cord",
    
    x %in% c("Midbrain") ~ "Midbrain",
    
    x %in% c("Hindbrain") ~ "Hindbrain",
    
    x %in% c("Node", "Notochord", "Node/Notochord") ~ "Node/Notochord",
    
    x %in% c("NMP", "NMPs", "Neuromesodermal progenitors") ~ "NMP",
    
    x %in% c(
      "Paraxial mesoderm",
      "Presomitic mesoderm",
      "Somitic mesoderm",
      "Anterior somitic tissues",
      "Posterior somitic tissues",
      "Dermomyotome",
      "Sclerotome",
      "Endotome",
      "Paraxial meso (PxM)"
    ) ~ "Paraxial meso (PxM)",
    
    x %in% c(
      "Cardiopharyngeal mesoderm",
      "Cardiopharyngeal meso",
      "Cardiopharyngeal meso (Cardioph)"
    ) ~ "Cardiopharyngeal meso (Cardioph)",
    
    x %in% c(
      "Intermediate mesoderm",
      "Intermediate meso",
      "Intermediate meso (IM)"
    ) ~ "Intermediate meso (IM)",
    
    x %in% c(
      "Lateral plate mesoderm",
      "LPM",
      "Limb mesoderm",
      "LPM (Limb meso)"
    ) ~ "LPM (Limb meso)",
    
    x %in% c("Endothelium", "Endothelial cells") ~ "Endothelium",
    
    x %in% c(
      "Definitive endoderm",
      "Foregut",
      "Midgut",
      "Hindgut",
      "Gut tube",
      "Definitive endoderm/Gut"
    ) ~ "Definitive endoderm/Gut",
    
    TRUE ~ x
  )
}

